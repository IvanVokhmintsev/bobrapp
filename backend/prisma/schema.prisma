generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  musician
  label
}

enum MusicianLevel {
  nothing
  beginner
  advanced
  professional
}

enum PostType {
  professional
  roadmap
}

enum RoadmapStepStatus {
  locked
  available
  completed
}

enum AchievementType {
  roadmap
  professional
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  musicianProfile MusicianProfile?
  posts           Post[]
  postLikes       PostLike[]
  comments        Comment[]
  reposts         Repost[]
  following       Follow[] @relation("user_follows")
  followers       Follow[] @relation("user_followers")
  roadmapProgress UserRoadmapProgress[]
  achievements    Achievement[]
}

model MusicianProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  level           MusicianLevel?
  bio             String?
  avatarUrl       String?
  location        String?
  genres          String[]       @default([])
  instruments     String[]       @default([])
  daw             String[]       @default([])
  socialLinks     Json           @default("{}")
  points          Int            @default(0)
  roadmapProgress Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id         String   @id @default(uuid())
  authorId   String
  text       String
  type       PostType
  likesCount Int      @default(0)
  commentsCount Int   @default(0)
  repostsCount Int    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postLikes PostLike[]
  comments Comment[]
  reposts  Repost[]
}

model PostLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Repost {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("user_follows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("user_followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model RoadmapStep {
  id           String   @id @default(uuid())
  title        String
  description  String
  order        Int      @unique
  content      String
  checklist    Json
  quiz         Json     @default("[]")
  pointsReward Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userProgress UserRoadmapProgress[]
}

model UserRoadmapProgress {
  id          String            @id @default(uuid())
  userId      String
  stepId      String
  status      RoadmapStepStatus
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  step RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([userId, stepId])
}

model Achievement {
  id          String          @id @default(uuid())
  userId      String
  title       String
  description String?
  type        AchievementType
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
