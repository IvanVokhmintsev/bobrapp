generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProfileType {
  solo
  band
}

enum UserRole {
  musician
  label
}

enum MusicianLevel {
  nothing
  beginner
  advanced
  professional
}

enum PostType {
  professional
  roadmap
}

enum RoadmapStepStatus {
  locked
  available
  completed
}

enum AchievementType {
  roadmap
  professional
}

model ProfileAlbum {
  id                String   @id @default(uuid())
  musicianProfileId String
  title             String
  releaseDate       DateTime?
  coverUrl          String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  musicianProfile MusicianProfile @relation(fields: [musicianProfileId], references: [id], onDelete: Cascade)

  @@index([musicianProfileId, sortOrder])
}

model ProfileConcert {
  id                String   @id @default(uuid())
  musicianProfileId String
  venue             String
  eventDate         DateTime
  coverUrl          String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  musicianProfile MusicianProfile @relation(fields: [musicianProfileId], references: [id], onDelete: Cascade)

  @@index([musicianProfileId, sortOrder])
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  musicianProfile MusicianProfile?
  posts           Post[]
  postLikes       PostLike[]
  comments        Comment[]
  reposts         Repost[]
  following       Follow[] @relation("user_follows")
  followers       Follow[] @relation("user_followers")
  favoriteArtists FavoriteArtist[] @relation("user_favorite_artists")
  favoritedBy     FavoriteArtist[] @relation("artist_favorited_by")
  favoritePosts   FavoritePost[]
  roadmapProgress UserRoadmapProgress[]
  achievements    Achievement[]
}

model MusicianProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  profileType     ProfileType    @default(solo)
  level           MusicianLevel?
  bio             String?
  avatarUrl       String?
  location        String?
  genres          String[]       @default([])
  instruments     String[]       @default([])
  daw             String[]       @default([])
  memberNames     String[]       @default([])
  socialLinks     Json           @default("{}")
  points          Int            @default(0)
  roadmapProgress Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  albums   ProfileAlbum[]
  concerts ProfileConcert[]
}

model Post {
  id            String   @id @default(uuid())
  authorId      String
  text          String
  type          PostType
  imageUrl      String?
  audioUrl      String?
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  repostsCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postLikes PostLike[]
  comments Comment[]
  reposts  Repost[]
  favoritePosts FavoritePost[]
}

model PostLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Repost {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("user_follows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("user_followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model FavoriteArtist {
  id        String   @id @default(uuid())
  userId    String
  artistId  String
  createdAt DateTime @default(now())

  user   User @relation("user_favorite_artists", fields: [userId], references: [id], onDelete: Cascade)
  artist User @relation("artist_favorited_by", fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId])
  @@index([userId, createdAt])
}

model FavoritePost {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

model RoadmapStep {
  id           String   @id @default(uuid())
  title        String
  description  String
  order        Int      @unique
  content      String
  checklist    Json
  quiz         Json     @default("[]")
  pointsReward Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userProgress UserRoadmapProgress[]
}

model UserRoadmapProgress {
  id          String            @id @default(uuid())
  userId      String
  stepId      String
  status      RoadmapStepStatus
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  step RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([userId, stepId])
}

model Achievement {
  id          String          @id @default(uuid())
  userId      String
  title       String
  description String?
  type        AchievementType
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
